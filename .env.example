# Neon Postgres connection string
DATABASE_URL=postgresql://neondb_owner:xxx@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT secret for session tokens (generate a random 64-char string)
JWT_SECRET=generate-a-random-64-char-string-here

# Password hash for login (generated during setup, or use: node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)")
# AUTH_PASSWORD_HASH=$2a$10$...

# Optional: Anthropic API key for AI features (can also be set in app Settings after setup)
# ANTHROPIC_API_KEY=sk-ant-xxx
