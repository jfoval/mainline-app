# Required: Neon Postgres connection string (free at neon.tech)
DATABASE_URL=postgresql://neondb_owner:xxx@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional: JWT secret for session tokens
# If not set, a secure secret is auto-generated on first launch and stored in your database.
# JWT_SECRET=generate-a-random-64-char-string-here

# Optional: Password hash for login (set during the setup wizard, or generate manually)
# AUTH_PASSWORD_HASH=$2a$10$...

# Optional: Anthropic API key for AI features (can also be set in Settings after setup)
# ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: Timezone for schedule, daily notes, and timestamps (IANA format)
# Defaults to America/Chicago. Can also be set in Settings after setup.
# TIMEZONE=America/Chicago
